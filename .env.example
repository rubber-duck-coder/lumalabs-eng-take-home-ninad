# Rename to `.env` and fill in the values you need.
# Keep secrets out of git; this file is safe to commit as a reference.

APP_ENV=local
DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<db>?sslmode=disable
SEED_DEMO_DATA=true
WEB_PORT=5173
API_PORT=8080
AWS_REGION=us-west-2
CORS_ALLOW_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional provider credentials used only if you integrate those services.
OPENAI_API_KEY=<openai_api_key>
ANTHROPIC_API_KEY=<anthropic_api_key>
GOOGLE_CLOUD_PROJECT=<gcp_project_id>
GOOGLE_APPLICATION_CREDENTIALS=<path_to_service_account_json>
AWS_ACCESS_KEY_ID=<aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
